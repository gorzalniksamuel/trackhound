{
  "name": "tracehound",
  "version": "0.1.0",
  "description": "Sniff out what your AI agent is doing - know exactly what your AI agent did",
  "main": "dist/index.js",
  "bin": {
    "tracehound": "dist/cli.js",
    "th": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "agents",
    "codex",
    "claude",
    "openclaw",
    "auditing",
    "observability",
    "trace",
    "hound",
    "security",
    "recording",
    "cli",
    "developer-tools"
  ],
  "author": "Samuel Gorzalnik <gorzalniksamuel@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gorzalniksamuel/tracehound.git"
  },
  "bugs": {
    "url": "https://github.com/gorzalniksamuel/tracehound/issues"
  },
  "homepage": "https://github.com/gorzalniksamuel/tracehound#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ]
}
